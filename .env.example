# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Optional PostgreSQL connection string.
# If omitted, a high-performance local SQLite database (`lwex.db`) is automatically initialized and used.
DATABASE_URL=""

# NOWPAYMENTS CONFIGURATION (Crypto Deposits & Withdrawals)
# Get these settings from your NOWPAYMENTS merchant dashboard: https://nowpayments.io/
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""
NOWPAYMENTS_BASE_URL="https://api.nowpayments.io/v1" # Use https://api-sandbox.nowpayments.io/v1 for testing
NOWPAYMENTS_WITHDRAWALS_ENABLED="false"
IPN_CALLBACK_URL=""

# TELEGRAM BOT INTEGRATION
# Setup a bot via Telegram's @BotFather to broadcast signals and community stats
TELEGRAM_BOT_TOKEN=""
TELEGRAM_GROUP_CHAT_ID=""

# ADMIN MANAGEMENT
# Secure key for authorizing admin overrides and outcome forcing
ADMIN_KEY="admin-secret-key"
